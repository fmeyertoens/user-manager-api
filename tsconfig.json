{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "moduleResolution": "NodeNext"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["dist", "node_modules"]
}
